# --- REQUIRED ---
# Your PIS number (numbers only or with punctuation)
PIS=your_pis_here
# Paid CAPTCHA bypass token 
CAPSOLVER_API_KEY=your_capsolver_api_key_here

# --- OPTIONAL FEATURES ---
# If provided, sends a summary embed + PDF attachment on success
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here
# If provided, attempts free audio CAPTCHA bypass before CapSolver
WIT_AI_TOKEN=your_wit_ai_token_here

# --- FILE SAVING TOGGLES ---
# Set to 'true' to save these artifacts inside the output/ folder
SAVE_PDF=false
SAVE_JSON=false

# --- SCHEDULING (Docker only) ---
# Example: 8:00 AM on the 16th of every month
CRON_SCHEDULE=0 8 16 * *

# --- ADVANCED / RETRY CONFIGURATION ---
CAPSOLVER_MAX_RETRIES=5
CAPTCHA_RETRY_ATTEMPTS=2
PROCESS_RETRY_ATTEMPTS=2
PROCESS_RETRY_DELAY_MINUTES=5

# --- LOGGING ---
LOG_LEVEL=info
LOG_FILE=false
DEBUG=false
